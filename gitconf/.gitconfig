[user]
    name = Volodymyr Masliy
    email = thebestvova@gmail.com

[includeIf "gitdir:~/work/"]
    path = ~/work/.gitconfig_include
[pager]
    branch = true
[core]
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    side-by-side = true

[merge]
    conflictStyle = zdiff3

[pull]
    rebase = true
[alias]
    co = checkout
    st = status
    poh = push origin HEAD
    br = branch
    fa = fetch --all
    dfs = diff --staged
    df = diff
    sw = switch
[log]
	date = local
